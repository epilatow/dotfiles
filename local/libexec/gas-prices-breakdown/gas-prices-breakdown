# ---------------------------------------------------------------------------
# Fetch helpers
# ---------------------------------------------------------------------------

def _http(url: str, *, decode: bool = True) -> bytes | str:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": USER_AGENT,
            "Accept": (
                "text/html,application/xhtml+xml,application/xml;q=0.9,"
                "*/*;q=0.8"
            ),
            "Accept-Language": "en-US,en;q=0.9",
            "Accept-Encoding": "gzip",
        },
    )
    with urllib.request.urlopen(req, timeout=60) as resp:
        body = resp.read()
        if resp.headers.get("Content-Encoding") == "gzip":
            body = gzip.decompress(body)
    if decode:
        return body.decode("utf-8", errors="replace")
    return body


def most_recent_thursday(today: date | None = None) -> date:
    today = today or date.today()
    return today - timedelta(days=(today.weekday() - 3) % 7)


# ---------------------------------------------------------------------------
# AAA retail
# ---------------------------------------------------------------------------

def fetch_aaa_retail() -> dict[str, float]:
    html = _http(AAA_URL)
    table_match = re.search(
        r'<table[^>]*id="sortable"[^>]*>(.*?)</table>',
        html, re.S,
    )
    if not table_match:
        raise RuntimeError("AAA: sortable table not found on page")
    rows = re.findall(r"<tr[^>]*>(.*?)</tr>", table_match.group(1), re.S)
    out: dict[str, float] = {}
    for tr in rows[1:]:
        tds = re.findall(r"<td[^>]*>(.*?)</td>", tr, re.S)
        if not tds:
            continue
        name_match = re.search(r"<a[^>]*>(.*?)</a>", tds[0], re.S)
        if not name_match:
            continue
        state = re.sub(r"\s+", " ", name_match.group(1)).strip()
        state = state.replace("&amp;", "&")
        if state not in STATE_CODE:
            raise RuntimeError(f"AAA: unrecognized state {state!r}")
        if len(tds) < 2:
            raise RuntimeError(f"AAA: missing price columns for {state}")
        clean = re.sub(r"<[^>]+>", "", tds[1])
        clean = re.sub(r"\s+", " ", clean).strip().lstrip("$")
        out[STATE_CODE[state]] = float(clean)
    if len(out) != 51:
        raise RuntimeError(f"AAA: parsed {len(out)} states, expected 51")
    return out


# ---------------------------------------------------------------------------
# CARB LCFS weekly
# ---------------------------------------------------------------------------

@dataclass(frozen=True)
class LcfsWeek:
    monday: date
    vwap_per_mt: float
    source_xlsx_url: str


def fetch_lcfs_for_target_date(target: date, cache_dir: Path) -> LcfsWeek:
    """Return the most recent LCFS weekly VWAP available as of `target`.

    CARB reports cover Mon-Sun and are published the following Tuesday;
    target date D can use the week-of-Monday X iff X + 8 days <= D."""
    landing = _http(CARB_LCFS_LANDING)
    href_match = re.search(
        r'href="([^"]*Weekly[^"]*\.xlsx)"',
        landing,
    )
    if not href_match:
        raise RuntimeError("CARB LCFS: xlsx link not found on landing page")
    url = href_match.group(1)
    if url.startswith("/"):
        url = "https://ww2.arb.ca.gov" + url
    xlsx_path = cache_dir / "lcfs.xlsx"
    xlsx_path.write_bytes(_http(url, decode=False))  # type: ignore[arg-type]
    weeks = _read_lcfs_weekly(xlsx_path)
    cutoff = target - timedelta(days=8)
    selected: tuple[date, float] | None = None
    for monday, vwap in weeks:
        if monday <= cutoff:
            selected = (monday, vwap)
        else:
            break
    if selected is None:
        raise RuntimeError(f"CARB LCFS: no week with monday <= {cutoff}")
    return LcfsWeek(monday=selected[0], vwap_per_mt=selected[1],
                    source_xlsx_url=url)


def _read_lcfs_weekly(path: Path) -> list[tuple[date, float]]:
    wb = openpyxl.load_workbook(path, data_only=True)
    sheet_name = "Weekly Average Credit Price"
    if sheet_name not in wb.sheetnames:
        raise RuntimeError(f"CARB LCFS xlsx missing sheet {sheet_name!r}")
    sh = wb[sheet_name]
    weeks: list[tuple[date, float]] = []
    for row in sh.iter_rows(min_row=2, values_only=True):
        a = row[0]
        if a is None or not hasattr(a, "year"):
            continue
        monday = a.date() if hasattr(a, "date") else a  # type: ignore[union-attr]
        b = row[1]
        if not isinstance(b, (int, float)):
            continue
        weeks.append((monday, float(b)))
    if not weeks:
        raise RuntimeError("CARB LCFS xlsx: no weekly rows parsed")
    return weeks


